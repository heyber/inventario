generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String   @id @default(cuid())
  name     String?
  email    String   @unique
  password String
  products Product[]
}

model Product {
  id          String @id @default(cuid())
  name        String
  description String
  price       Float
  stock       Int
  userId      String
  user        User @relation(fields: [userId], references: [id])
}