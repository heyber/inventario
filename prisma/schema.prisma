generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String  @unique
  password String

  city    String?
  company String?
  phone   String?

  createdAt DateTime @default(now())

  products        Product[]
  inventories     Inventory[]
  inventoryFiles  InventoryFile[]   
}

model Product {
  id          String @id @default(cuid())
  name        String
  description String
  price       Float
  stock       Int
  userId      String
  user        User   @relation(fields: [userId], references: [id])
}

model Inventory {
  id           String   @id @default(cuid())
  userId       String
  codigo       Int
  producto     String
  disponibilidad Int
  precio       Float
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model InventoryFile {
  id          String   @id @default(cuid())
  name        String
  description String?
  data        Json     // 🔥 aquí va TODO el Excel
  userId      String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
